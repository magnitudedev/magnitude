{
  "$schema": "../../../schemas/case.schema.json",
  "schema_version": "1",
  "id": "correctness.cancellation.decode-abort-recovery",
  "title": "Decode recovery after a pre-signalled abort",
  "description": "Observe one pre-signalled abort in a matched CPU-resident context, remove the callback, clear logical memory, then compare a successful one-token recovery decode and only its selected logits.",
  "category": "correctness",
  "primitive": "C11",
  "adapter": "differential",
  "operation": "decode.abort-recovery",
  "status": "active",
  "tags": ["model-smoke", "oracle-smoke"],
  "source": {
    "kind": "upstream-derived",
    "upstream_file": "include/llama.h",
    "note": "This isolates reuse of the same context after an observed abort, callback removal, synchronization, and a full logical memory clear. It does not expose callback counts or private context state."
  },
  "inputs": {
    "nGpuLayers": 0,
    "useMmap": true,
    "useMlock": false,
    "contextTokens": 32,
    "threads": 1,
    "batchThreads": 1,
    "offloadKqv": false,
    "operationOffload": false,
    "flashAttention": "off",
    "token": 1,
    "logitIndices": [0, 1, 2, 3]
  },
  "requirements": {
    "offline": true,
    "fixtures": [],
    "model": { "all_tags": ["decoder-only"] },
    "capabilities": ["decode.abort-recovery"]
  },
  "invocations": {
    "reference": { "kind": "native-oracle", "target": "oracle", "operation": "decode.abort-recovery" },
    "candidate": { "kind": "icn-probe", "target": "icn-probe", "operation": "decode.abort-recovery" }
  },
  "comparison": {
    "kind": "numeric",
    "paths": ["/recovery/logits"],
    "exact_paths": ["/abort", "/recovery/status"],
    "absolute_tolerance": 0.00001,
    "relative_tolerance": 0.00001,
    "nan_equal": false
  }
}
