{
  "$schema": "../../../schemas/case.schema.json",
  "schema_version": "1",
  "id": "performance.llama-bench.generation-128",
  "title": "Same-work 128-token generation decode",
  "description": "Compare official llama-bench token-generation decode with the low-level ICN candidate; tokenization, sampling, and output conversion are absent.",
  "category": "performance",
  "primitive": "P2",
  "adapter": "upstream-tool",
  "operation": "llama-bench.token-generation",
  "status": "active",
  "tags": ["model-smoke", "same-work"],
  "prerequisites": [
    "correctness.config.context-defaults",
    "correctness.metadata.stable-fields",
    "correctness.decode.single-batch-logits"
  ],
  "source": {
    "kind": "upstream-defined",
    "upstream_file": "tools/llama-bench/llama-bench.cpp",
    "upstream_case": "test_gen"
  },
  "inputs": {
    "prompt_tokens": 0,
    "generation_tokens": 128,
    "context_depth": 0,
    "batch_tokens": 512,
    "micro_batch_tokens": 512,
    "repetitions": 10,
    "warmup": true,
    "token_schedule": "pinned-llama-bench-c-rand-default",
    "effective_engine_configuration": "profile"
  },
  "requirements": {
    "offline": true,
    "fixtures": [],
    "model": { "all_tags": ["decoder-only"] },
    "capabilities": ["llama-bench", "single-token-decode"]
  },
  "invocations": {
    "reference": { "kind": "upstream-tool", "target": "llama-bench", "operation": "llama-bench.token-generation" },
    "candidate": { "kind": "icn-probe", "target": "icn-probe", "operation": "llama-bench.token-generation" }
  },
  "comparison": {
    "kind": "performance-ratio",
    "metric": "tokens_per_second",
    "statistic": "median",
    "minimum_ratio": 0.97,
    "direction": "candidate-over-reference",
    "exact_output_paths": [""]
  },
  "timing": {
    "included": ["thread-count application", "one-token batch preparation", "decode calls", "backend synchronization"],
    "excluded": ["model load", "context construction", "memory clear", "warm-up", "sampling", "result serialization"],
    "warmup_iterations": 1,
    "measurement_iterations": 10,
    "synchronize": true
  }
}
