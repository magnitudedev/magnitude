{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magnitude.dev/schemas/inference/parity/evidence.schema.json",
  "title": "ICN primitive parity evidence",
  "description": "One engine's immutable observation for one primitive parity case.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "case_id",
    "category",
    "primitive",
    "operation",
    "recorded_at",
    "producer",
    "outcome",
    "work",
    "output",
    "measurements",
    "provenance",
    "warnings"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1" },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "case_id": {
      "type": "string",
      "pattern": "^(correctness|performance)\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "category": { "enum": ["correctness", "performance"] },
    "primitive": { "type": "string", "pattern": "^[CP](?:[0-9]|1[0-3])$" },
    "operation": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": { "$ref": "#/$defs/producer" },
    "outcome": { "$ref": "#/$defs/outcome" },
    "work": { "$ref": "#/$defs/work" },
    "output": {
      "description": "Operation-specific JSON value. Byte strings are encoded as explicit objects by the operation protocol, never as lossy Unicode."
    },
    "measurements": {
      "type": "array",
      "items": { "$ref": "#/$defs/measurement" }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "category": { "const": "correctness" } },
        "required": ["category"]
      },
      "then": {
        "properties": { "primitive": { "type": "string", "pattern": "^C(?:[0-9]|1[0-3])$" } }
      }
    },
    {
      "if": {
        "properties": { "category": { "const": "performance" } },
        "required": ["category"]
      },
      "then": {
        "properties": {
          "primitive": { "type": "string", "pattern": "^P[0-8]$" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": { "const": "performance" },
          "outcome": {
            "properties": { "class": { "const": "success" } },
            "required": ["class"]
          }
        },
        "required": ["category", "outcome"]
      },
      "then": {
        "properties": {
          "measurements": { "type": "array", "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "name"],
      "properties": {
        "role": { "enum": ["qualification", "reference", "candidate"] },
        "kind": { "enum": ["upstream-test", "upstream-tool", "native-oracle", "icn-probe"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "binary_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class"],
      "properties": {
        "class": {
          "enum": ["success", "unsupported", "invalid-input", "cancelled", "runtime-error", "skipped"]
        },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" }
      }
    },
    "work": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameters", "included", "excluded"],
      "properties": {
        "parameters": { "type": "object" },
        "included": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "item_count": { "type": "integer", "minimum": 0 },
        "plan_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "samples"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
        },
        "unit": {
          "enum": ["ns", "us", "ms", "s", "tokens/s", "bytes/s", "GB/s", "FLOP/s", "bytes", "count", "ratio"]
        },
        "samples": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 1
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "enum": ["native-source", "bindings-source", "icn-source", "oracle-binary", "probe-binary", "upstream-binary", "runner"]
        },
        "name": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "tree_sha256": { "$ref": "#/$defs/sha256" },
        "binary_sha256": { "$ref": "#/$defs/sha256" },
        "dirty": { "type": "boolean" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_type", "compiler", "compiler_version", "flags", "assertions", "sanitizers"],
      "properties": {
        "build_type": { "enum": ["debug", "release", "relwithdebinfo", "minsizerel", "unknown"] },
        "compiler": { "type": "string", "minLength": 1 },
        "compiler_version": { "type": "string", "minLength": 1 },
        "flags": { "type": "array", "items": { "type": "string" } },
        "assertions": { "type": ["boolean", "null"] },
        "sanitizers": {
          "oneOf": [
            { "type": "array", "items": { "type": "string", "minLength": 1 } },
            { "type": "null" }
          ]
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "cpu"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "os_version": { "type": "string" },
        "arch": { "type": "string", "minLength": 1 },
        "cpu": { "type": "string", "minLength": 1 },
        "logical_cpus": { "type": "integer", "minimum": 1 },
        "memory_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "name"],
      "properties": {
        "backend": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "driver": { "type": "string" },
        "runtime": { "type": "string" },
        "memory_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "sha256", "bytes"],
      "properties": {
        "kind": { "enum": ["model", "vocabulary", "fixture", "corpus", "media", "projector"] },
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "build", "host", "devices", "artifacts", "effective_configuration"],
      "properties": {
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" },
          "minItems": 1
        },
        "build": { "$ref": "#/$defs/build" },
        "host": { "$ref": "#/$defs/host" },
        "devices": {
          "type": "array",
          "items": { "$ref": "#/$defs/device" }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" }
        },
        "effective_configuration": { "type": "object" },
        "environment_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
