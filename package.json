{
  "name": "magnitude",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["cli", "evals", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd packages/llm-core baml && bun run cli/src/index.tsx --debug",
    "build": "turbo build && bun run cli/scripts/build-binary.ts",
    "typecheck": "turbo typecheck",
    "test": "bun test",
    "session": "bun run --cwd evals session",
    "tbench": "bun run evals/tbench/cli.ts",
    "dash": "bun run --cwd packages/tracing dashboard",
    "events": "cat ~/.magnitude/logs/events.jsonl",
    "events:tail": "tail -f ~/.magnitude/logs/events.jsonl",
    "events:copy": "cat ~/.magnitude/logs/events.jsonl | pbcopy && echo 'Events copied to clipboard'",
    "logs": "cat ~/.magnitude/logs/cli.jsonl",
    "logs:tail": "tail -f ~/.magnitude/logs/cli.jsonl",
    "logs:copy": "cat ~/.magnitude/logs/cli.jsonl | pbcopy && echo 'Logs copied to clipboard'",
    "cs": "changeset",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "pre:alpha": "changeset pre enter alpha",
    "pre:beta": "changeset pre enter beta",
    "pre:exit": "changeset pre exit",
    "prepare": "effect-language-service patch",
    "els": "effect-language-service"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.8",
    "@types/mdast": "^4.0.4",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "@effect/language-service": "^0.84.1"
  },
  "dependencies": {
    "beautiful-mermaid": "^0.1.3",
    "mdast-util-from-markdown": "^2.0.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-wiki-link": "^2.0.1"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "patchedDependencies": {
    "@opentui/core@0.1.88": "patches/@opentui%2Fcore@0.1.88.patch"
  }
}
