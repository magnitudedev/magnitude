{
  "name": "@magnitudedev/cli-source",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "bin": {
    "magnitude": "bin/magnitude"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "bun run ../packages/version/scripts/generate-version.ts --dev && bun run src/index.tsx",
    "build:binary": "bun run scripts/build-binary.ts",
    "typecheck": "bun run ../packages/version/scripts/generate-version.ts && tsc --noEmit",
    "test": "bunx --bun vitest run src/persistence/json-chat-persistence.test.ts src/persistence/session-utils.test.ts",
    "test:all": "bunx --bun vitest run",
    "logs": "bun run --cwd ../evals session logs",
    "logs:tail": "bun run --cwd ../evals session logs --tail",
    "logs:clear": "bun run --cwd ../evals session logs --clear"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@opentui/core": "0.1.88",
    "@opentui/react": "0.1.88",
    "@magnitudedev/generate-id": "workspace:*",
    "@magnitudedev/sdk": "workspace:*",
    "@magnitudedev/client-common": "workspace:*",
    "@magnitudedev/version": "workspace:*",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.90.0",
    "beautiful-mermaid": "^0.1.3",
    "commander": "^14.0.1",
    "effect": "^3.21.2",
    "fast-json-patch": "^3.1.1",
    "immer": "^10.1.3",
    "lowlight": "^3.3.0",
    "pino": "^10.3.0",
    "react": "^19.0.0",
    "string-width": "^8.1.1",
    "ansis": "^3.17.0"
  },
  "devDependencies": {
    "@magnitudedev/logger": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3"
  }
}
