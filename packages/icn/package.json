{
  "name": "@magnitudedev/icn",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./src/generated/schemas.ts",
    "./lifecycle": "./src/lifecycle/index.ts",
    "./hardware": "./src/hardware/index.ts",
    "./catalog": "./src/catalog/index.ts",
    "./installed": "./src/installed/index.ts",
    "./downloads": "./src/downloads/index.ts",
    "./provider": "./src/provider/index.ts"
  },
  "scripts": {
    "generate": "bun run scripts/generate.ts",
    "check-generated": "bun run scripts/generate.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "bunx --bun vitest run"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@magnitudedev/ai": "workspace:*",
    "@magnitudedev/openapi-effect": "workspace:*",
    "@noble/hashes": "^2.2.0",
    "effect": "3.21.2"
  },
  "devDependencies": {
    "@effect/platform-bun": "^0.90.0",
    "@types/bun": "latest",
    "vitest": "^3.2.4"
  }
}
