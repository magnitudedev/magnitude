{
  "openapi": "3.1.0",
  "info": {
    "title": "Magnitude Inference Control Node",
    "description": "",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "ICN is running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/apply-template": {
      "post": {
        "tags": [
          "chat"
        ],
        "operationId": "applyChatTemplate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApplyTemplateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Prepared llama.cpp chat prompt and constraints",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplyTemplateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Template preparation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/completions": {
      "post": {
        "tags": [
          "chat"
        ],
        "operationId": "createChatCompletion",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OpenAI-compatible server-sent events",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-magnitude-stream": {
          "data": {
            "encoding": "json",
            "schema": {
              "$ref": "#/components/schemas/ChatCompletionChunk"
            }
          },
          "framing": "sse",
          "reconnect": {
            "type": "none"
          },
          "responseStatus": 200,
          "termination": {
            "type": "sentinel",
            "value": "[DONE]"
          },
          "version": 1
        }
      }
    },
    "/v1/models": {
      "get": {
        "tags": [
          "models"
        ],
        "operationId": "listModels",
        "responses": {
          "200": {
            "description": "Loaded models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelList"
                }
              }
            }
          }
        }
      }
    },
    "/v1/props": {
      "get": {
        "tags": [
          "models"
        ],
        "operationId": "getModelProperties",
        "responses": {
          "200": {
            "description": "Loaded model and active template properties",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PropsResponse"
                }
              }
            }
          },
          "500": {
            "description": "Properties unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
