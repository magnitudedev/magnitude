{
  "name": "@magnitudedev/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "src/index.ts",
      "import": "src/index.ts"
    },
    "./protocol": {
      "types": "src/protocol.ts",
      "import": "src/protocol.ts"
    }
  },
  "scripts": {
    "typecheck": "bun run ../version/scripts/generate-version.ts && tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "@effect/platform": "^0.96.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/rpc": "0.75.1",
    "@magnitudedev/ai": "workspace:*",
    "@magnitudedev/providers": "workspace:*",
    "@magnitudedev/protocol": "workspace:*",
    "@magnitudedev/storage": "workspace:*",

    "@magnitudedev/roles": "workspace:*",
    "@magnitudedev/utils": "workspace:*",
    "@magnitudedev/version": "workspace:*"
  },
  "devDependencies": {
    "@effect/platform-bun": "^0.90.0",
    "vitest": "^3.2.4"
  }
}
