{
  "present": true,
  "client": {
    "baseURL": "https://ai-gateway.vercel.sh/v1"
  },
  "args": {
    "model": "openai/gpt-5.4",
    "input": "What are the top AI news headlines today? Include sources.",
    "tools": [
      {
        "type": "web_search"
      }
    ],
    "include": [
      "web_search_call.action.sources"
    ]
  }
}
