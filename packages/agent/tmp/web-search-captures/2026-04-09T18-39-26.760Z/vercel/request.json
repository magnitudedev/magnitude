{
  "present": true,
  "client": {
    "baseURL": "https://ai-gateway.vercel.sh/v1",
    "sdk": "ai"
  },
  "args": {
    "model": "openai/gpt-5.4",
    "prompt": "latest AI headlines with sources",
    "tools": {
      "web_search": {
        "type": "provider-defined",
        "id": "openai.web_search_preview",
        "args": {},
        "parameters": {
          "_def": {
            "unknownKeys": "strip",
            "catchall": {
              "_def": {
                "typeName": "ZodNever"
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              }
            },
            "typeName": "ZodObject"
          },
          "~standard": {
            "version": 1,
            "vendor": "zod"
          },
          "_cached": null
        }
      }
    }
  }
}
