{
  "name": "@magnitudedev/local-inference",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./model-files": "./src/model-files/index.ts",
    "./huggingface": "./src/huggingface/index.ts",
    "./hardware": "./src/hardware/index.ts",
    "./llamacpp": "./src/llamacpp/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bunx --bun vitest run",
    "verify:package": "bun run typecheck && bun run test",
    "verify:huggingface": "bun scripts/verify-huggingface.ts",
    "verify:llama-cli": "bun scripts/verify-llama-cli.ts",
    "verify:external-readonly": "bun scripts/verify-external-readonly.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@huggingface/gguf": "0.4.2",
    "@huggingface/hub": "2.13.3",
    "@huggingface/tasks": "0.21.24",
    "@magnitudedev/ai": "workspace:*",
    "effect": "3.21.2"
  },
  "devDependencies": {
    "@effect/platform-bun": "^0.90.0",
    "@types/bun": "latest",
    "vitest": "^3.2.4"
  }
}
