{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@magnitudedev/agent": ["../packages/agent/src"],
      "@magnitudedev/llm-core": ["../packages/llm-core/src"],
      "@magnitudedev/js-act": ["../packages/js-act/src"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
