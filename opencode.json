{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["magnitude-icn"],
  "model": "magnitude-icn/qwen3-1.7b",
  "small_model": "magnitude-icn/qwen3-1.7b",
  "provider": {
    "magnitude-icn": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Magnitude ICN (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3-1.7b": {
          "name": "Qwen3 1.7B (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B-A3B (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "gemma-4-e2b-it": {
          "name": "Gemma 4 E2B IT (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "gemma-4-e4b-it": {
          "name": "Gemma 4 E4B IT (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "gemma-4-26b-a4b-it": {
          "name": "Gemma 4 26B-A4B IT (local ICN)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },
        "icn-fake": {
          "name": "ICN fake backend",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        }
      }
    }
  }
}
